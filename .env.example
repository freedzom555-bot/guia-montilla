# Google Places API — fotos y datos de Google Maps
# https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_PLACES_API_KEY=

# Producción — guiamontilla.es
SITE_URL=https://guiamontilla.es
BASE_PATH=/

# Despliegue IONOS (solo en GitHub Secrets, no subir aquí):
# IONOS_FTP_SERVER=accessXXXX.webspace-data.io
# IONOS_FTP_USERNAME=tu-usuario-ftp
# IONOS_FTP_PASSWORD=tu-contraseña
# IONOS_FTP_SERVER_DIR=/

# Opcional — reescritura IA en pipeline de eventos:
GEMINI_API_KEY=
