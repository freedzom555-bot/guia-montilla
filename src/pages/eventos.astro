---
import Layout from "../layouts/Layout.astro";
import events from "../../data/events.json";

const sorted = [...events].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<Layout title="Agenda de Montilla" description="Eventos y actividades en Montilla. Actualizado automáticamente.">
  <section class="page-head">
    <div class="wrap">
      <a href={import.meta.env.BASE_URL} class="back">← Inicio</a>
      <h1>Agenda</h1>
      <p class="page-head__sub">Lo que pasa en el pueblo, recogido de fuentes públicas.</p>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      {sorted.length > 0 ? (
        <ul class="agenda">
          {sorted.map((ev) => {
            const d = new Date(ev.date);
            return (
              <li class="agenda-item">
                <time class="agenda-item__when" datetime={ev.date}>
                  {d.toLocaleDateString("es-ES", { weekday: "short", day: "numeric", month: "long" })}
                </time>
                <div>
                  <h2 class="agenda-item__title">
                    {ev.url ? (
                      <a href={ev.url} target="_blank" rel="noopener noreferrer">{ev.title}</a>
                    ) : (
                      ev.title
                    )}
                  </h2>
                  {ev.excerpt && <p class="agenda-item__excerpt">{ev.excerpt}</p>}
                </div>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="empty-note">Sin eventos indexados todavía.</p>
      )}
    </div>
  </section>
</Layout>
