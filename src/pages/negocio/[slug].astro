---
import Layout from "../../layouts/Layout.astro";
import PhotoGallery from "../../components/PhotoGallery.astro";
import RelatedPlaces from "../../components/RelatedPlaces.astro";
import businesses from "../../../data/businesses.json";
import categories from "../../../data/categories.json";
import { SITE } from "../../data/site";
import {
  businessTitle,
  businessDescription,
  businessKeywords,
  buildBusinessSchemas,
  seoGalleryImages,
} from "../../lib/seo";
import { displayTagline } from "../../lib/business";
import { NEGOCIO_CATEGORY_IDS } from "../../lib/categoryImages";

export function getStaticPaths() {
  return businesses.map((business) => ({
    params: { slug: business.slug },
    props: { business },
  }));
}

const { business } = Astro.props;
const category = categories.find((c) => c.id === business.category);
const categoryName = category?.name ?? "Montilla";
const base = import.meta.env.BASE_URL;
const siteUrl = (Astro.site ?? new URL("http://localhost:4321")).href.replace(/\/$/, "");
const pageUrl = new URL(`${base}negocio/${business.slug}/`, siteUrl).href;
const isNegocioCat = (NEGOCIO_CATEGORY_IDS as readonly string[]).includes(business.category);
const categoryUrl = new URL(`${base}${business.category}/`, siteUrl).href;

const rawGallery = business.gallery?.length
  ? business.gallery
  : business.image
    ? [{ src: business.image, alt: business.name }]
    : [];

const gallery = seoGalleryImages(rawGallery, business, categoryName, base);
const imagesForSchema = gallery.map((g) => new URL(g.href, siteUrl).href);

const metaTitle = businessTitle(business.name, categoryName);
const metaDescription = businessDescription(business, categoryName);
const metaKeywords = businessKeywords(business, categoryName);
const ogImage = gallery[0]?.src ?? "/images/og-default.jpg";
const tagline = displayTagline(business);
const paragraphs = (business.description ?? "")
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

const hoursLines =
  business.hoursList?.length > 0
    ? business.hoursList
    : business.hours
      ? [business.hours]
      : [];

const schemas = buildBusinessSchemas({
  business,
  categoryName,
  categoryUrl,
  pageUrl,
  siteUrl,
  siteName: SITE.name,
  images: imagesForSchema,
  metaTitle,
  metaDescription,
});
---

<Layout
  title={metaTitle}
  description={metaDescription}
  keywords={metaKeywords}
  image={ogImage}
  ogType="website"
  includeSiteSchema={false}
  jsonLd={schemas}
>
  <article class="business-page" itemscope itemtype="https://schema.org/LocalBusiness">
    <meta itemprop="name" content={business.name} />
    {business.phone && <meta itemprop="telephone" content={business.phone} />}
    {gallery[0] && <meta itemprop="image" content={new URL(gallery[0].href, siteUrl).href} />}

    <section class="page-head">
      <div class="wrap">
        <nav class="breadcrumb" aria-label="Ruta de navegación">
          <a href={base}>Inicio</a>
          <span aria-hidden="true"> / </span>
          {isNegocioCat && (
            <>
              <a href={`${base}negocios/`}>Negocios</a>
              <span aria-hidden="true"> / </span>
            </>
          )}
          <a href={`${base}${business.category}/`}>{categoryName}</a>
          <span aria-hidden="true"> / </span>
          <span aria-current="page">{business.name}</span>
        </nav>
        <div class="page-head__meta">
          {business.featured && (
            <span class="pill">{business.slug === "kyvera-digital" ? "Patrocinio" : "Destacado"}</span>
          )}
          <span class="pill pill--muted">{categoryName}</span>
          {business.rating && (
            <span class="pill pill--muted">
              {business.rating.toFixed(1)} ★
              {business.reviewCount ? ` (${business.reviewCount})` : ""}
            </span>
          )}
        </div>
        <h1>{business.name}</h1>
        <p class="page-head__sub">{tagline}</p>
      </div>
    </section>

    <div class="wrap">
      {gallery.length > 0 ? (
        <PhotoGallery images={gallery} name={business.name} />
      ) : (
        <p class="no-photos">Sin fotos en esta ficha.</p>
      )}
    </div>

    <div class="wrap page-body">
      <div class="page-body__prose">
        <section class="info-block info-block--about">
          <h2>Sobre este lugar</h2>
          {paragraphs.map((para, i) => (
            <p class:list={[{ "description-lead": i === 0 }]} itemprop={i === 0 ? "description" : undefined}>
              {para}
            </p>
          ))}
        </section>

        {business.highlights?.length > 0 && (
          <section class="info-block info-block--highlights">
            <h2>En resumen</h2>
            <ul class="highlights-list">
              {business.highlights.map((h) => <li>{h}</li>)}
            </ul>
          </section>
        )}

        {business.tips && (
          <section class="info-block info-block--tip">
            <h2>Consejo</h2>
            <p>{business.tips}</p>
          </section>
        )}

        <RelatedPlaces current={business} all={businesses} />
      </div>

      <aside class="sidebox" aria-label="Datos prácticos">
        <h2 class="sidebox__title">Datos prácticos</h2>

        {business.businessStatusLabel && (
          <p class="status-badge">{business.businessStatusLabel}</p>
        )}

        <dl class="contact-dl">
          {business.address && (
            <>
              <dt>Dirección</dt>
              <dd itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                <span itemprop="streetAddress">{business.address}</span>
                <span class="visually-hidden">
                  <span itemprop="addressLocality">Montilla</span>
                  <span itemprop="postalCode">14550</span>
                  <span itemprop="addressRegion">Córdoba</span>
                  <span itemprop="addressCountry">ES</span>
                </span>
              </dd>
            </>
          )}
          {business.phone && (
            <>
              <dt>Teléfono</dt>
              <dd>
                <a href={`tel:${business.phone.replace(/\s/g, "")}`} itemprop="telephone">{business.phone}</a>
              </dd>
            </>
          )}
          {business.email && (
            <>
              <dt>Correo</dt>
              <dd>
                <a href={`mailto:${business.email}`} itemprop="email">{business.email}</a>
              </dd>
            </>
          )}
          {business.web && (
            <>
              <dt>Web</dt>
              <dd>
                <a href={business.web} target="_blank" rel="noopener noreferrer" itemprop="url">
                  {business.web.replace(/^https?:\/\/(www\.)?/, "")}
                </a>
              </dd>
            </>
          )}
          {business.priceRange && (
            <>
              <dt>Precio</dt>
              <dd itemprop="priceRange">{business.priceRange}</dd>
            </>
          )}
          {business.payment && (
            <>
              <dt>Pago</dt>
              <dd>{business.payment}</dd>
            </>
          )}
          {business.accessibility && (
            <>
              <dt>Accesibilidad</dt>
              <dd>{business.accessibility}</dd>
            </>
          )}
        </dl>

        {hoursLines.length > 0 && (
          <div class="sidebox__hours">
            <h3>Horario</h3>
            <ul class="hours-list">
              {hoursLines.map((line) => <li>{line}</li>)}
            </ul>
            <p class="info-note">Confirma el día de tu visita.</p>
          </div>
        )}

        {business.social?.length > 0 && (
          <ul class="social-links">
            {business.social.map((url) => (
              <li>
                <a href={url} target="_blank" rel="noopener noreferrer">
                  {url.includes("instagram")
                    ? "Instagram"
                    : url.includes("facebook")
                      ? "Facebook"
                      : "Red social"}
                </a>
              </li>
            ))}
          </ul>
        )}

        {business.googleMapsUrl && (
          <a
            class="btn btn--maps"
            href={business.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Cómo llegar
          </a>
        )}
      </aside>
    </div>
  </article>
</Layout>

<style>
  .page-head__sub {
    max-width: 40rem;
  }
  .description-lead {
    font-size: 1.08rem;
    line-height: 1.65;
  }
  .info-block--about p + p {
    margin-top: 0.85rem;
  }
  .info-block--tip {
    padding: 1rem 1.15rem;
    background: var(--wine-light);
    border-left: 3px solid var(--wine);
  }
  .info-block--tip h2 {
    margin-top: 0;
  }
  .info-note {
    margin: 0.5rem 0 0;
    font-size: 0.8rem;
    color: var(--ink-muted);
  }
  .sidebox__title {
    font-size: 1rem;
    margin: 0 0 var(--space-2);
  }
  .sidebox__hours {
    margin: 1rem 0;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
  }
  .sidebox__hours h3 {
    margin: 0 0 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .contact-dl dd {
    margin-bottom: 0.75rem;
  }
  .btn--maps {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.75rem 1.1rem;
    background: var(--wine);
    color: oklch(0.98 0.01 80);
    border-radius: 2px;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    width: 100%;
  }
  .btn--maps:hover {
    background: var(--wine-deep);
  }
  .social-links {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
  }
  .hours-list {
    margin: 0;
    padding-left: 1.1rem;
    line-height: 1.65;
    font-size: 0.9rem;
  }
  .status-badge {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.25rem 0.65rem;
    background: #e8f5e9;
    color: #2e7d32;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .pill--muted {
    background: rgba(0, 0, 0, 0.06);
    color: inherit;
  }
</style>
