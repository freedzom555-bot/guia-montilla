---
import categories from "../../data/categories.json";
import { LEGAL, SITE } from "../data/site";

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-foot">
  <div class="wrap site-foot__grid">
    <div class="site-foot__brand">
      <a href={base} aria-label="Guía Montilla — inicio">
        <img
          class="site-foot__logo"
          src={`${base}images/logo-guia-montilla.png`}
          alt="Guía Montilla — Todo Montilla, en un solo lugar"
          width="140"
          height="184"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p>Directorio verificado de Montilla-Moriles. Bodegas, mesas, parques, monumentos y planes.</p>
    </div>
    <div>
      <h4>Secciones</h4>
      <ul>
        {categories.map((cat) => (
          <li><a href={`${base}${cat.slug}/`}>{cat.name}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <h4>Legal</h4>
      <ul>
        <li><a href={`${base}aviso-legal/`}>Aviso legal</a></li>
        <li><a href={`${base}politica-privacidad/`}>Privacidad</a></li>
        <li><a href={`${base}politica-cookies/`}>Cookies</a></li>
      </ul>
    </div>
    <div>
      <h4>Contacto</h4>
      <ul>
        <li><a href={`tel:+34${SITE.phone.replace(/\s/g, "")}`}>{SITE.phone}</a></li>
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li><a href={LEGAL.developerUrl} rel="noopener noreferrer" target="_blank">kyveradigital.es</a></li>
      </ul>
    </div>
    <div>
      <h4>Negocios</h4>
      <ul>
        <li><a href={`${base}para-negocios/`}>Aparecer destacado</a></li>
        <li><a href={`${base}noticias/`}>Noticias Montilla</a></li>
        <li><a href={`${base}blog/`}>Blog Montilla</a></li>
        <li><a href={`${base}eventos/`}>Agenda</a></li>
      </ul>
    </div>
  </div>
  <div class="wrap site-foot__copy">
    © {year} Guía Montilla · Medio automatizado · Fuentes públicas
    <span class="site-foot__credit">
      Creado por <a href="https://kyveradigital.es" rel="noopener noreferrer" target="_blank">Kyvera Digital</a>
    </span>
  </div>
</footer>
