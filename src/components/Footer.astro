---
import { SITE } from "../data/site";

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-foot">
  <div class="wrap site-foot__grid">
    <div class="site-foot__brand">
      <a href={base} aria-label="Guía Montilla — inicio">
        <img
          class="site-foot__logo"
          src={`${base}images/logo-guia-montilla.png`}
          alt="Guía Montilla — Todo Montilla, en un solo click"
          width="140"
          height="184"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p>Directorio verificado de Montilla-Moriles. Bodegas, mesas, parques, monumentos, negocios y senderismo.</p>
    </div>
    <div>
      <h4>Secciones</h4>
      <ul>
        <li><a href={`${base}bodegas/`}>Bodegas</a></li>
        <li><a href={`${base}restaurantes/`}>Restaurantes</a></li>
        <li><a href={`${base}monumentos/`}>Monumentos</a></li>
        <li><a href={`${base}rutas/`}>Rutas</a></li>
        <li><a href={`${base}negocios/`}>Negocios</a></li>
      </ul>
    </div>
    <div>
      <h4>Descubrir</h4>
      <ul>
        <li><a href={`${base}museos/`}>Museos</a></li>
        <li><a href={`${base}parques/`}>Parques</a></li>
        <li><a href={`${base}cultura-ocio/`}>Cultura y ocio</a></li>
        <li><a href={`${base}noticias/`}>Noticias</a></li>
        <li><a href={`${base}blog/`}>Blog</a></li>
      </ul>
    </div>
    <div>
      <h4>Legal</h4>
      <ul>
        <li><a href={`${base}aviso-legal/`}>Aviso legal</a></li>
        <li><a href={`${base}politica-privacidad/`}>Privacidad</a></li>
        <li><a href={`${base}politica-cookies/`}>Cookies</a></li>
      </ul>
    </div>
    <div>
      <h4>Patrocinio</h4>
      <ul>
        <li><a href={`${base}negocio/kyvera-digital/`}>Kyvera Digital</a></li>
        <li><a href={`${base}para-negocios/`}>Anunciar tu negocio</a></li>
        <li><a href={`tel:+34${SITE.phone.replace(/\s/g, "")}`}>{SITE.phone}</a></li>
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
      </ul>
    </div>
  </div>
  <div class="wrap site-foot__copy">
    © {year} Guía Montilla · Medio automatizado · Fuentes públicas
    <span class="site-foot__credit">
      Creado por <a href={`${base}negocio/kyvera-digital/`}>Kyvera Digital</a>
    </span>
  </div>
</footer>
