---
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images: GalleryImage[];
  name: string;
}

const { images, name } = Astro.props;
const base = import.meta.env.BASE_URL;
const resolved = images.map((img) => ({
  ...img,
  href: `${base}${img.src.replace(/^\//, "")}`,
}));
const main = resolved[0];
---

{resolved.length > 0 && (
  <div class="gallery" data-gallery>
    <div class="gallery__main">
      <img
        src={main.href}
        alt={main.alt}
        width="1200"
        height="675"
        loading="eager"
        fetchpriority="high"
        data-gallery-main
      />
    </div>
    {resolved.length > 1 && (
      <div class="gallery__thumbs" role="tablist" aria-label={`Fotos de ${name}`}>
        {resolved.map((img, i) => (
          <button
            type="button"
            class:list={["gallery__thumb", { "is-active": i === 0 }]}
            role="tab"
            aria-selected={i === 0}
            aria-label={img.alt}
            data-gallery-thumb={img.href}
            data-gallery-alt={img.alt}
          >
            <img src={img.href} alt="" width="120" height="80" loading="lazy" />
          </button>
        ))}
      </div>
    )}
  </div>
)}

<script>
  document.querySelectorAll("[data-gallery]").forEach((root) => {
    const main = root.querySelector("[data-gallery-main]");
    const thumbs = root.querySelectorAll("[data-gallery-thumb]");

    thumbs.forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.getAttribute("data-gallery-thumb");
        const alt = btn.getAttribute("data-gallery-alt");
        if (main && src) {
          main.src = src;
          if (alt) main.alt = alt;
        }
        root.querySelectorAll(".gallery__thumb").forEach((t) => {
          const active = t === btn;
          t.classList.toggle("is-active", active);
          t.setAttribute("aria-selected", String(active));
        });
      });
    });
  });
</script>

<style>
  .gallery {
    margin-bottom: var(--space-4);
  }
  .gallery__main {
    aspect-ratio: 16 / 9;
    background: var(--wine-light);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }
  .gallery__thumbs {
    display: flex;
    gap: var(--space-1);
    margin-top: var(--space-2);
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }
  .gallery__thumb {
    flex: 0 0 5.5rem;
    aspect-ratio: 4 / 3;
    padding: 0;
    border: 2px solid transparent;
    background: var(--wine-light);
    cursor: pointer;
    overflow: hidden;
  }
  .gallery__thumb.is-active {
    border-color: var(--wine);
  }
  .gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .gallery__thumb:focus-visible {
    outline: 2px solid var(--wine);
    outline-offset: 2px;
  }
</style>
