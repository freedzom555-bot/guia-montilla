---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { SEO } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  keywords?: string;
  ogType?: string;
  includeSiteSchema?: boolean;
}

const {
  title = SEO.defaultTitle,
  description = SEO.defaultDescription,
  image = SEO.ogImage,
  jsonLd,
  noindex = false,
  keywords,
  ogType = "website",
  includeSiteSchema = true,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("http://localhost:4321");
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(`${base}${image.replace(/^\//, "")}`, siteUrl).href;
const fullTitle = title.includes("Guía Montilla") ? title : `${title} · Guía Montilla`;

const defaultSchema = includeSiteSchema
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${siteUrl.href}#website`,
      name: "Guía Montilla",
      url: siteUrl.href,
      description: SEO.defaultDescription,
      inLanguage: "es-ES",
      potentialAction: {
        "@type": "SearchAction",
        target: `${new URL(`${base}buscar/`, siteUrl).href}?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    }
  : null;

const schemas = jsonLd
  ? Array.isArray(jsonLd)
    ? defaultSchema
      ? [defaultSchema, ...jsonLd]
      : jsonLd
    : defaultSchema
      ? [defaultSchema, jsonLd]
      : [jsonLd]
  : defaultSchema
    ? [defaultSchema]
    : [];
---

<!doctype html>
<html lang="es-ES">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="author" content="Guía Montilla" />
    <meta name="geo.region" content="ES-CO" />
    <meta name="geo.placename" content="Montilla, Córdoba" />
    <meta name="geo.position" content="37.5863;-4.6381" />
    <meta name="ICBM" content="37.5863, -4.6381" />
    <meta name="theme-color" content="#4a1f1c" />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon-16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Guía Montilla" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <title>{fullTitle}</title>

    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <script>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("in")),
          { threshold: 0.06 }
        );
        document.querySelectorAll(".fade-in").forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll(".fade-in").forEach((el) => el.classList.add("in"));
      }
    </script>
  </body>
</html>
